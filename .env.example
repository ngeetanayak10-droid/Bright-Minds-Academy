# =====================================================
#  . — Environment Variables
#  Copy this file to ".env" and fill in your values.
#  NEVER commit .env to git — it's in .gitignore.
# =====================================================

# The email address that sends form notification emails
# ✏️ FILL IN: Your Gmail (or other SMTP) address
EMAIL_USER=hello@brightmindsacademy.com

# For Gmail: create an "App Password" at https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
# ✏️ FILL IN: Your email app password (NOT your normal login password)
EMAIL_PASS=your_app_password_here

# Where form submissions get delivered — usually same as EMAIL_USER
# ✏️ FILL IN: The inbox you want to receive contact forms
EMAIL_TO=hello@brightmindsacademy.com

# Port the server listens on (3000 is fine for local dev; hosting platforms set this automatically)
PORT=3000
